<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="240.0" styleClass="sidebar"
      stylesheets="@../styles/styles.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.SidebarController">

    <VBox styleClass="logo-container" alignment="CENTER_LEFT">
        <Label styleClass="logo-text" text="Aktour" />
        <Label styleClass="logo-subtitle" text="ViaBalkan" style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;" />
    </VBox>

    <VBox spacing="4.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets left="12.0" right="12.0" top="16.0" />
        </padding>
        <Button fx:id="btnDashboard"      maxWidth="Infinity" styleClass="nav-button" text="  Dashboard"             onAction="#onDashboard" />
        <Button fx:id="btnTourManagement" maxWidth="Infinity" styleClass="nav-button" text="  Tour Management"       onAction="#onTourManagement" />
        <Button fx:id="btnExpenseTracker" maxWidth="Infinity" styleClass="nav-button" text="  Expense Tracker"       onAction="#onExpenseTracker" />
        <Button fx:id="btnVehiclesGuides" maxWidth="Infinity" styleClass="nav-button" text="  Vehicles &amp; Guides"  onAction="#onVehiclesGuides" />
    </VBox>

    <VBox>
        <padding>
            <Insets bottom="20.0" left="12.0" right="12.0" top="12.0" />
        </padding>
        <Separator styleClass="sidebar-separator">
            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
        </Separator>
        <Button maxWidth="Infinity" styleClass="logout-button" text="  Logout" />
    </VBox>

</VBox>
